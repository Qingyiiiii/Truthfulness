{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:claim-warehouse-export-manifest:v1",
  "title": "Claim warehouse export manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_schema_version",
    "export_id",
    "run_id",
    "run_created_at",
    "created_at",
    "export_idempotency_key",
    "storage_root_ref",
    "manifest_relative_path",
    "rows_relative_path",
    "rows_hash",
    "logical_hash",
    "row_count",
    "row_counts",
    "source_registry_prefix",
    "input_artifacts",
    "schema_versions",
    "taxonomy_versions",
    "exporter_versions"
  ],
  "properties": {
    "manifest_schema_version": {"const": "claim_warehouse_export_v1.0.0"},
    "export_id": {"$ref": "#/$defs/exportId"},
    "run_id": {"pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "run_created_at": {"$ref": "#/$defs/utc"},
    "created_at": {"$ref": "#/$defs/utc"},
    "export_idempotency_key": {"$ref": "#/$defs/sha256"},
    "storage_root_ref": {"$ref": "#/$defs/rootRef"},
    "manifest_relative_path": {"type": "string", "pattern": "^exports/export_[0-9a-hjkmnp-tv-z]{26}/manifest\\.json$"},
    "rows_relative_path": {"type": "string", "pattern": "^exports/export_[0-9a-hjkmnp-tv-z]{26}/rows\\.jsonl$"},
    "rows_hash": {"$ref": "#/$defs/sha256"},
    "logical_hash": {"$ref": "#/$defs/sha256"},
    "row_count": {"type": "integer", "minimum": 1},
    "row_counts": {"$ref": "#/$defs/countMap"},
    "source_registry_prefix": {"$ref": "#/$defs/registryPrefix"},
    "input_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/inputArtifact"}
    },
    "schema_versions": {"$ref": "#/$defs/versionMap"},
    "taxonomy_versions": {"$ref": "#/$defs/versionMap"},
    "exporter_versions": {"$ref": "#/$defs/versionMap"}
  },
  "$defs": {
    "exportId": {"type": "string", "pattern": "^export_[0-9a-hjkmnp-tv-z]{26}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "rootRef": {"const": "ubuntu_v02_claim_warehouse"},
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "countMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "integer", "minimum": 1},
      "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"}
    },
    "versionMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "registryPrefix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_count", "prefix_hash", "head_record_id", "head_record_hash"],
      "properties": {
        "record_count": {"type": "integer", "minimum": 0},
        "prefix_hash": {"$ref": "#/$defs/sha256"},
        "head_record_id": {"type": ["string", "null"], "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$"},
        "head_record_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "inputArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "record_id", "artifact_type", "content_hash"],
      "properties": {
        "artifact_id": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
        "record_id": {"type": "string", "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$"},
        "artifact_type": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"},
        "content_hash": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
