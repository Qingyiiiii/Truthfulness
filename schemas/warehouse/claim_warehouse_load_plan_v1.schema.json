{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:claim-warehouse-load-plan:v1",
  "title": "Claim warehouse immutable load plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "load_plan_schema_version", "load_plan_id", "created_at",
    "storage_root_ref", "plan_relative_path", "warehouse_projection_version",
    "exports", "ordered_export_set_hash", "plan_hash"
  ],
  "properties": {
    "load_plan_schema_version": {"const": "claim_warehouse_load_plan_v1.0.0"},
    "load_plan_id": {"$ref": "#/$defs/loadPlanId"},
    "created_at": {"$ref": "#/$defs/utc"},
    "storage_root_ref": {"$ref": "#/$defs/rootRef"},
    "plan_relative_path": {"type": "string", "pattern": "^receipts/load_plan_[0-9a-hjkmnp-tv-z]{26}\\.json$"},
    "warehouse_projection_version": {"const": "claim_warehouse_projection_v1.0.0"},
    "exports": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {"$ref": "#/$defs/exportBinding"}
    },
    "ordered_export_set_hash": {"$ref": "#/$defs/sha256"},
    "plan_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "loadPlanId": {"type": "string", "pattern": "^load_plan_[0-9a-hjkmnp-tv-z]{26}$"},
    "exportId": {"type": "string", "pattern": "^export_[0-9a-hjkmnp-tv-z]{26}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "rootRef": {"const": "ubuntu_v02_claim_warehouse"},
    "relativePath": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "logicalLayer": {"enum": ["core_provenance", "machine_screening", "source_depth", "human_annotation", "analytics_mart"]},
    "exportBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["export_id", "export_idempotency_key", "source_run_id", "source_registry_ref", "logical_layer", "storage_root_ref", "manifest_relative_path", "manifest_hash", "rows_hash", "logical_hash", "row_count"],
      "properties": {
        "export_id": {"$ref": "#/$defs/exportId"},
        "export_idempotency_key": {"$ref": "#/$defs/sha256"},
        "source_run_id": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
        "source_registry_ref": {"$ref": "#/$defs/sourceRegistryRef"},
        "logical_layer": {"$ref": "#/$defs/logicalLayer"},
        "storage_root_ref": {"$ref": "#/$defs/rootRef"},
        "manifest_relative_path": {"type": "string", "pattern": "^exports/export_[0-9a-hjkmnp-tv-z]{26}/manifest\\.json$"},
        "manifest_hash": {"$ref": "#/$defs/sha256"},
        "rows_hash": {"$ref": "#/$defs/sha256"},
        "logical_hash": {"$ref": "#/$defs/sha256"},
        "row_count": {"type": "integer", "minimum": 1}
      }
    },
    "sourceRegistryRef": {
      "type": "object", "additionalProperties": false,
      "required": ["storage_root_ref", "relative_path"],
      "properties": {
        "storage_root_ref": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
        "relative_path": {"type": "string", "pattern": "^runs/V02/run_[0-9a-hjkmnp-tv-z]{26}/artifact_registry\\.jsonl$"}
      }
    }
  }
}
