{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:claim-warehouse-load-receipt:v1",
  "title": "Claim warehouse immutable load receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "load_receipt_schema_version", "receipt_id", "receipt_relative_path",
    "load_batch", "exports", "parquet_manifest", "row_counts", "watermark",
    "dependency_versions", "duckdb_transaction_marker", "receipt_hash"
  ],
  "properties": {
    "load_receipt_schema_version": {"const": "claim_warehouse_load_receipt_v1.0.0"},
    "receipt_id": {"$ref": "#/$defs/loadReceiptId"},
    "receipt_relative_path": {"type": "string", "pattern": "^receipts/load_receipt_[0-9a-hjkmnp-tv-z]{26}\\.json$"},
    "load_batch": {"$ref": "#/$defs/loadBatch"},
    "exports": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/$defs/exportBinding"}},
    "parquet_manifest": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/parquetFile"}},
    "row_counts": {"$ref": "#/$defs/countMap"},
    "watermark": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/exportId"}},
    "dependency_versions": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}},
    "duckdb_transaction_marker": {"$ref": "#/$defs/sha256"},
    "receipt_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "exportId": {"type": "string", "pattern": "^export_[0-9a-hjkmnp-tv-z]{26}$"},
    "loadPlanId": {"type": "string", "pattern": "^load_plan_[0-9a-hjkmnp-tv-z]{26}$"},
    "loadBatchId": {"type": "string", "pattern": "^load_batch_[0-9a-hjkmnp-tv-z]{26}$"},
    "loadReceiptId": {"type": "string", "pattern": "^load_receipt_[0-9a-hjkmnp-tv-z]{26}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "relativePath": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "logicalLayer": {"enum": ["core_provenance", "machine_screening", "source_depth", "human_annotation", "analytics_mart"]},
    "countMap": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "integer", "minimum": 1}, "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"}},
    "exportBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["export_id", "export_idempotency_key", "source_run_id", "source_registry_ref", "logical_layer", "storage_root_ref", "manifest_relative_path", "manifest_hash", "rows_hash", "logical_hash", "row_count"],
      "properties": {
        "export_id": {"$ref": "#/$defs/exportId"}, "export_idempotency_key": {"$ref": "#/$defs/sha256"},
        "source_run_id": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
        "source_registry_ref": {"$ref": "#/$defs/sourceRegistryRef"}, "logical_layer": {"$ref": "#/$defs/logicalLayer"},
        "storage_root_ref": {"const": "ubuntu_v02_claim_warehouse"},
        "manifest_relative_path": {"type": "string", "pattern": "^exports/export_[0-9a-hjkmnp-tv-z]{26}/manifest\\.json$"}, "manifest_hash": {"$ref": "#/$defs/sha256"},
        "rows_hash": {"$ref": "#/$defs/sha256"}, "logical_hash": {"$ref": "#/$defs/sha256"},
        "row_count": {"type": "integer", "minimum": 1}
      }
    },
    "sourceRegistryRef": {
      "type": "object", "additionalProperties": false,
      "required": ["storage_root_ref", "relative_path"],
      "properties": {
        "storage_root_ref": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$"},
        "relative_path": {"type": "string", "pattern": "^runs/V02/run_[0-9a-hjkmnp-tv-z]{26}/artifact_registry\\.jsonl$"}
      }
    },
    "loadBatch": {
      "type": "object", "additionalProperties": false,
      "required": ["load_batch_schema_version", "load_batch_id", "load_plan_id", "load_plan_hash", "started_at", "completed_at", "status", "export_count", "row_count", "logical_hash", "batch_hash"],
      "properties": {
        "load_batch_schema_version": {"const": "claim_warehouse_load_batch_v1.0.0"},
        "load_batch_id": {"$ref": "#/$defs/loadBatchId"}, "load_plan_id": {"$ref": "#/$defs/loadPlanId"},
        "load_plan_hash": {"$ref": "#/$defs/sha256"}, "started_at": {"$ref": "#/$defs/utc"},
        "completed_at": {"$ref": "#/$defs/utc"}, "status": {"const": "succeeded"},
        "export_count": {"type": "integer", "minimum": 1, "maximum": 100},
        "row_count": {"type": "integer", "minimum": 1}, "logical_hash": {"$ref": "#/$defs/sha256"},
        "batch_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "parquetFile": {
      "type": "object", "additionalProperties": false,
      "required": ["logical_layer", "table_code", "export_id", "relative_path", "size_bytes", "file_hash", "row_count", "row_logical_hash"],
      "properties": {
        "logical_layer": {"$ref": "#/$defs/logicalLayer"}, "table_code": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "export_id": {"$ref": "#/$defs/exportId"}, "relative_path": {"type": "string", "pattern": "^parquet/logical_layer=[a-z_]+/table_code=[a-z0-9_]+/schema_version=truthfulness_db_v02\\.1\\.0/run_date=[0-9]{4}-[0-9]{2}-[0-9]{2}/export_id=export_[0-9a-hjkmnp-tv-z]{26}/part-00000\\.parquet$"},
        "size_bytes": {"type": "integer", "minimum": 1}, "file_hash": {"$ref": "#/$defs/sha256"},
        "row_count": {"type": "integer", "minimum": 1}, "row_logical_hash": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
