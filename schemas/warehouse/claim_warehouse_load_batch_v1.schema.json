{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:claim-warehouse-load-batch:v1",
  "title": "Claim warehouse committed load batch v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "load_batch_schema_version", "load_batch_id", "load_plan_id",
    "load_plan_hash", "started_at", "completed_at", "status",
    "export_count", "row_count", "logical_hash", "batch_hash"
  ],
  "properties": {
    "load_batch_schema_version": {"const": "claim_warehouse_load_batch_v1.0.0"},
    "load_batch_id": {"$ref": "#/$defs/loadBatchId"},
    "load_plan_id": {"$ref": "#/$defs/loadPlanId"},
    "load_plan_hash": {"$ref": "#/$defs/sha256"},
    "started_at": {"$ref": "#/$defs/utc"},
    "completed_at": {"$ref": "#/$defs/utc"},
    "status": {"const": "succeeded"},
    "export_count": {"type": "integer", "minimum": 1, "maximum": 100},
    "row_count": {"type": "integer", "minimum": 1},
    "logical_hash": {"$ref": "#/$defs/sha256"},
    "batch_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "loadBatchId": {"type": "string", "pattern": "^load_batch_[0-9a-hjkmnp-tv-z]{26}$"},
    "loadPlanId": {"type": "string", "pattern": "^load_plan_[0-9a-hjkmnp-tv-z]{26}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"}
  }
}
