{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:handoff:v2",
  "title": "Video Truthfulness HANDOFF v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "handoff_version",
    "handoff_artifact_id",
    "handoff_scope",
    "project_version",
    "storage_version",
    "release_id",
    "task_id",
    "session_id",
    "attempt_no",
    "run_id",
    "stage_id",
    "status",
    "parent_checkpoint_id",
    "checkpoint_id",
    "agent_profile_version",
    "agent_runtime_version",
    "workflow_version",
    "dag_version",
    "schema_versions",
    "prompt_version",
    "code_ref",
    "source_event_head",
    "source_registry_heads",
    "input_artifacts",
    "output_artifacts",
    "declared_read_set",
    "declared_write_set",
    "actual_read_set",
    "actual_write_set",
    "invalidated_artifacts",
    "completed_actions",
    "remaining_actions",
    "risks",
    "human_decisions_required",
    "validation_summary",
    "metrics",
    "next_action",
    "render_profile_version",
    "created_at",
    "handoff_hash"
  ],
  "properties": {
    "handoff_version": {"const": "handoff_v2.0.0"},
    "handoff_artifact_id": {"$ref": "#/$defs/artifactId"},
    "handoff_scope": {"enum": ["run", "project"]},
    "project_version": {"const": "v0.2"},
    "storage_version": {"const": "V02"},
    "release_id": {"const": "truthfulness_v0.2_youtube_video"},
    "task_id": {"$ref": "#/$defs/taskId"},
    "session_id": {"$ref": "#/$defs/sessionId"},
    "attempt_no": {"type": "integer", "minimum": 1},
    "run_id": {
      "oneOf": [
        {"$ref": "#/$defs/runId"},
        {"type": "null"}
      ]
    },
    "stage_id": {"$ref": "#/$defs/stageId"},
    "status": {
      "enum": ["COMPLETED", "FAILED", "WAITING_FOR_HUMAN", "BLOCKED_BY_INPUT", "SKIPPED_BY_GATE"]
    },
    "parent_checkpoint_id": {
      "oneOf": [
        {"$ref": "#/$defs/checkpointId"},
        {"type": "null"}
      ]
    },
    "checkpoint_id": {"$ref": "#/$defs/checkpointId"},
    "agent_profile_version": {"$ref": "#/$defs/agentProfileVersion"},
    "agent_runtime_version": {"type": "string", "minLength": 1, "maxLength": 120},
    "workflow_version": {"const": "youtube_truthfulness_workflow_v1.1.0"},
    "dag_version": {"const": "youtube_truthfulness_dag_v1.1.0"},
    "schema_versions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/schemaVersion"},
      "uniqueItems": true,
      "contains": {"const": "handoff_v2.0.0"}
    },
    "prompt_version": {"$ref": "#/$defs/promptVersion"},
    "code_ref": {"$ref": "#/$defs/codeRef"},
    "source_event_head": {"$ref": "#/$defs/eventHead"},
    "source_registry_heads": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/registryHead"},
      "uniqueItems": true
    },
    "input_artifacts": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/artifactRef"},
      "uniqueItems": true
    },
    "output_artifacts": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/artifactRef"},
      "uniqueItems": true
    },
    "declared_read_set": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/scopeEntry"},
      "uniqueItems": true
    },
    "declared_write_set": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/scopeEntry"},
      "uniqueItems": true
    },
    "actual_read_set": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/observedAccess"},
      "uniqueItems": true
    },
    "actual_write_set": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/observedAccess"},
      "uniqueItems": true
    },
    "invalidated_artifacts": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/artifactRef"},
      "uniqueItems": true
    },
    "completed_actions": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/completedAction"},
      "uniqueItems": true
    },
    "remaining_actions": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/remainingAction"},
      "uniqueItems": true
    },
    "risks": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/risk"},
      "uniqueItems": true
    },
    "human_decisions_required": {
      "type": "array",
      "maxItems": 1024,
      "items": {"$ref": "#/$defs/humanDecisionRequirement"},
      "uniqueItems": true
    },
    "validation_summary": {"$ref": "#/$defs/validationSummary"},
    "metrics": {"$ref": "#/$defs/metrics"},
    "next_action": {"$ref": "#/$defs/nextAction"},
    "render_profile_version": {
      "type": "string",
      "pattern": "^handoff_markdown_renderer_v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {"$ref": "#/$defs/utcTimestamp"},
    "handoff_hash": {"$ref": "#/$defs/sha256"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"handoff_scope": {"const": "run"}},
        "required": ["handoff_scope"]
      },
      "then": {"properties": {"run_id": {"$ref": "#/$defs/runId"}}},
      "else": {"properties": {"run_id": {"type": "null"}}}
    }
  ],
  "$defs": {
    "taskId": {"type": "string", "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$"},
    "sessionId": {"type": "string", "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$"},
    "runId": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "artifactId": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
    "recordId": {"type": "string", "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$"},
    "checkpointId": {"type": "string", "pattern": "^checkpoint_[0-9a-hjkmnp-tv-z]{26}$"},
    "eventId": {"type": "string", "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$"},
    "stageId": {"type": "string", "pattern": "^S0[1-9]$"},
    "dagNodeId": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitObjectId": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!~)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)latest(?:/|$))(?!.*[\\\\*?$])[^\\r\\n]+$"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "promptVersion": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_prompt_v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "agentProfileVersion": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_agent_v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "artifactType": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "scopeEntry": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope_type", "artifact_id", "purpose"],
          "properties": {
            "scope_type": {"const": "artifact"},
            "artifact_id": {"$ref": "#/$defs/artifactId"},
            "purpose": {"type": "string", "minLength": 1, "maxLength": 200}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope_type", "relative_path", "purpose"],
          "properties": {
            "scope_type": {"const": "path"},
            "relative_path": {"$ref": "#/$defs/relativePath"},
            "purpose": {"type": "string", "minLength": 1, "maxLength": 200}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope_type", "relative_path", "recursive", "purpose"],
          "properties": {
            "scope_type": {"const": "path_prefix"},
            "relative_path": {"$ref": "#/$defs/relativePath"},
            "recursive": {"type": "boolean"},
            "purpose": {"type": "string", "minLength": 1, "maxLength": 200}
          }
        }
      ]
    },
    "eventHead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "sequence_no", "event_hash", "occurred_at"],
      "properties": {
        "event_id": {"$ref": "#/$defs/eventId"},
        "sequence_no": {"type": "integer", "minimum": 1},
        "event_hash": {"$ref": "#/$defs/sha256"},
        "occurred_at": {"$ref": "#/$defs/utcTimestamp"}
      }
    },
    "registryHead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_scope",
        "relative_path",
        "content_hash_algorithm",
        "content_hash",
        "record_count",
        "artifact_count",
        "head_record_id",
        "head_record_hash"
      ],
      "properties": {
        "registry_scope": {"enum": ["run", "cross_run"]},
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "content_hash_algorithm": {"const": "sha256"},
        "content_hash": {"$ref": "#/$defs/sha256"},
        "record_count": {"type": "integer", "minimum": 0},
        "artifact_count": {"type": "integer", "minimum": 0},
        "head_record_id": {
          "oneOf": [
            {"$ref": "#/$defs/recordId"},
            {"type": "null"}
          ]
        },
        "head_record_hash": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"record_count": {"const": 0}}, "required": ["record_count"]},
          "then": {
            "properties": {
              "artifact_count": {"const": 0},
              "head_record_id": {"type": "null"},
              "head_record_hash": {"type": "null"}
            }
          },
          "else": {
            "properties": {
              "head_record_id": {"$ref": "#/$defs/recordId"},
              "head_record_hash": {"$ref": "#/$defs/sha256"}
            }
          }
        }
      ]
    },
    "codeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit",
        "working_tree_dirty",
        "working_tree_manifest_path",
        "working_tree_manifest_hash"
      ],
      "properties": {
        "git_commit": {"$ref": "#/$defs/gitObjectId"},
        "working_tree_dirty": {"type": "boolean"},
        "working_tree_manifest_path": {
          "oneOf": [
            {"$ref": "#/$defs/relativePath"},
            {"type": "null"}
          ]
        },
        "working_tree_manifest_hash": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"working_tree_dirty": {"const": true}}, "required": ["working_tree_dirty"]},
          "then": {
            "properties": {
              "working_tree_manifest_path": {"$ref": "#/$defs/relativePath"},
              "working_tree_manifest_hash": {"$ref": "#/$defs/sha256"}
            }
          },
          "else": {
            "properties": {
              "working_tree_manifest_path": {"type": "null"},
              "working_tree_manifest_hash": {"type": "null"}
            }
          }
        }
      ]
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "record_id",
        "relative_path",
        "content_hash_algorithm",
        "content_hash",
        "input_fingerprint",
        "validation_status",
        "lifecycle_state"
      ],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/artifactId"},
        "artifact_type": {"$ref": "#/$defs/artifactType"},
        "record_id": {"$ref": "#/$defs/recordId"},
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "content_hash_algorithm": {"const": "sha256"},
        "content_hash": {"$ref": "#/$defs/sha256"},
        "input_fingerprint": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        },
        "validation_status": {"enum": ["not_validated", "passed", "failed", "partial"]},
        "lifecycle_state": {
          "enum": ["created", "validated", "frozen", "stale", "superseded", "invalid", "archived", "purged"]
        }
      }
    },
    "observedAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "record_id",
        "relative_path",
        "content_hash_algorithm",
        "content_hash",
        "event_id"
      ],
      "properties": {
        "artifact_id": {
          "oneOf": [
            {"$ref": "#/$defs/artifactId"},
            {"type": "null"}
          ]
        },
        "record_id": {
          "oneOf": [
            {"$ref": "#/$defs/recordId"},
            {"type": "null"}
          ]
        },
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "content_hash_algorithm": {"const": "sha256"},
        "content_hash": {"$ref": "#/$defs/sha256"},
        "event_id": {"$ref": "#/$defs/eventId"}
      }
    },
    "completedAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_key", "summary", "source_event_id"],
      "properties": {
        "action_key": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 120},
        "summary": {"type": "string", "minLength": 1, "maxLength": 500},
        "source_event_id": {"$ref": "#/$defs/eventId"}
      }
    },
    "remainingAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_key", "summary"],
      "properties": {
        "action_key": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 120},
        "summary": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_key", "severity", "summary", "mitigation", "blocking"],
      "properties": {
        "risk_key": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 120},
        "severity": {"enum": ["low", "medium", "high", "critical"]},
        "summary": {"type": "string", "minLength": 1, "maxLength": 500},
        "mitigation": {"type": "string", "minLength": 1, "maxLength": 500},
        "blocking": {"type": "boolean"}
      }
    },
    "humanDecisionRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_artifact_id", "gate_node_id", "reason"],
      "properties": {
        "decision_artifact_id": {"$ref": "#/$defs/artifactId"},
        "gate_node_id": {"$ref": "#/$defs/dagNodeId"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "validatorResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "validator_version", "result", "validation_artifact_id"],
      "properties": {
        "validator_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$", "maxLength": 160},
        "validator_version": {"type": "string", "minLength": 1, "maxLength": 120},
        "result": {"enum": ["passed", "failed", "partial"]},
        "validation_artifact_id": {
          "oneOf": [
            {"$ref": "#/$defs/artifactId"},
            {"type": "null"}
          ]
        }
      }
    },
    "validationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_status", "passed_count", "failed_count", "partial_count", "validators"],
      "properties": {
        "overall_status": {"enum": ["passed", "failed", "partial", "not_run"]},
        "passed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "partial_count": {"type": "integer", "minimum": 0},
        "validators": {
          "type": "array",
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/validatorResult"},
          "uniqueItems": true
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_count",
        "actual_read_count",
        "actual_write_count",
        "input_artifact_count",
        "output_artifact_count",
        "validation_passed_count",
        "validation_failed_count",
        "out_of_scope_detection_count",
        "rebuild_hash_match"
      ],
      "properties": {
        "event_count": {"type": "integer", "minimum": 1},
        "actual_read_count": {"type": "integer", "minimum": 0},
        "actual_write_count": {"type": "integer", "minimum": 0},
        "input_artifact_count": {"type": "integer", "minimum": 0},
        "output_artifact_count": {"type": "integer", "minimum": 0},
        "validation_passed_count": {"type": "integer", "minimum": 0},
        "validation_failed_count": {"type": "integer", "minimum": 0},
        "out_of_scope_detection_count": {"type": "integer", "minimum": 0},
        "rebuild_hash_match": {"type": "boolean"}
      }
    },
    "nextStageAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_type",
        "next_stage",
        "workflow_reference",
        "prompt_reference",
        "required_input_artifact_ids",
        "required_read_paths",
        "reason"
      ],
      "properties": {
        "action_type": {"const": "next_stage"},
        "next_stage": {"$ref": "#/$defs/stageId"},
        "workflow_reference": {"$ref": "#/$defs/relativePath"},
        "prompt_reference": {"$ref": "#/$defs/relativePath"},
        "required_input_artifact_ids": {
          "type": "array",
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/artifactId"},
          "uniqueItems": true
        },
        "required_read_paths": {
          "type": "array",
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/relativePath"},
          "uniqueItems": true
        },
        "reason": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "waitForHumanAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_type", "decision_artifact_ids", "reason"],
      "properties": {
        "action_type": {"const": "wait_for_human"},
        "decision_artifact_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/artifactId"},
          "uniqueItems": true
        },
        "reason": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "returnToStageAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_type",
        "target_stage",
        "workflow_reference",
        "prompt_reference",
        "required_input_artifact_ids",
        "required_read_paths",
        "reason"
      ],
      "properties": {
        "action_type": {"const": "return_to_stage"},
        "target_stage": {"$ref": "#/$defs/stageId"},
        "workflow_reference": {"$ref": "#/$defs/relativePath"},
        "prompt_reference": {"$ref": "#/$defs/relativePath"},
        "required_input_artifact_ids": {
          "type": "array",
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/artifactId"},
          "uniqueItems": true
        },
        "required_read_paths": {
          "type": "array",
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/relativePath"},
          "uniqueItems": true
        },
        "reason": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "terminateAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_type", "termination_kind", "reason"],
      "properties": {
        "action_type": {"const": "terminate"},
        "termination_kind": {"enum": ["project_complete", "process_terminated", "terminal_failure"]},
        "reason": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "nextAction": {
      "oneOf": [
        {"$ref": "#/$defs/nextStageAction"},
        {"$ref": "#/$defs/waitForHumanAction"},
        {"$ref": "#/$defs/returnToStageAction"},
        {"$ref": "#/$defs/terminateAction"}
      ]
    }
  }
}
