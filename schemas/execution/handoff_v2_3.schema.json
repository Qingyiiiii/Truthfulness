    "RegisteredArtifactRef": {
      "additionalProperties": false,
      "description": "Checkpoint Artifact reference; unlike event writes it must be Registry-backed.",
      "properties": {
        "artifact_id": {
          "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_type": {
          "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$",
          "title": "Artifact Type",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "content_hash_algorithm": {
          "const": "sha256",
          "title": "Content Hash Algorithm",
          "type": "string"
        },
        "input_fingerprint": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Input Fingerprint"
        },
        "lifecycle_state": {
          "enum": [
            "created",
            "validated",
            "frozen",
            "stale",
            "superseded",
            "invalid",
            "archived",
            "purged"
          ],
          "title": "Lifecycle State",
          "type": "string"
        },
        "record_id": {
          "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Record Id",
          "type": "string"
        },
        "relative_path": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "validation_status": {
          "enum": [
            "not_validated",
            "passed",
            "failed",
            "partial"
          ],
          "title": "Validation Status",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "artifact_type",
        "record_id",
        "relative_path",
        "content_hash_algorithm",
        "content_hash",
        "input_fingerprint",
        "validation_status",
        "lifecycle_state"
      ],
      "title": "RegisteredArtifactRef",
      "type": "object"
    },
