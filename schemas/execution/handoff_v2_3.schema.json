    "ArtifactScope": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "purpose": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "scope_type": {
          "const": "artifact",
          "title": "Scope Type",
          "type": "string"
        }
      },
      "required": [
        "scope_type",
        "artifact_id",
        "purpose"
      ],
      "title": "ArtifactScope",
      "type": "object"
    },
    "CodeRef": {
      "additionalProperties": false,
      "properties": {
        "git_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Git Commit",
          "type": "string"
        },
        "working_tree_dirty": {
          "title": "Working Tree Dirty",
          "type": "boolean"
        },
        "working_tree_manifest_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Working Tree Manifest Hash"
        },
        "working_tree_manifest_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Working Tree Manifest Path"
        }
      },
      "required": [
        "git_commit",
        "working_tree_dirty",
        "working_tree_manifest_path",
        "working_tree_manifest_hash"
      ],
      "title": "CodeRef",
      "type": "object"
    },
    "CompletedAction": {
      "additionalProperties": false,
