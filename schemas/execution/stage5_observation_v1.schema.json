{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:stage5-observation:v1",
  "title": "Video Truthfulness Stage 5 Observation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observation_version", "observation_type", "observation_id", "sequence_no", "recorded_at",
    "task_id", "session_id", "attempt_no", "run_id", "stage_id", "node_id", "actor_role",
    "tool_name", "tool_profile", "exit_code", "accelerator_peak_memory_bytes",
    "retry_parent_session_id", "rework_observation_ids", "supersedes_observation_ids",
    "started_at", "finished_at", "active_elapsed_ms", "input_files", "output_files",
    "model_event_ids", "model_summary", "external_cost", "failure_class", "invalid_read_count",
    "scope", "previous_record_hash", "record_hash"
  ],
  "properties": {
    "observation_version": {"const": "stage5_observation_v1.0.0"},
    "observation_type": {"enum": ["observation.recorded", "observation.closed"]},
    "observation_id": {"$ref": "#/$defs/eventId"},
    "sequence_no": {"type": "integer", "minimum": 1},
    "recorded_at": {"$ref": "#/$defs/utcTimestamp"},
    "task_id": {"$ref": "#/$defs/taskId"},
    "session_id": {"$ref": "#/$defs/sessionId"},
    "attempt_no": {"type": "integer", "minimum": 1},
    "run_id": {"$ref": "#/$defs/runId"},
    "stage_id": {"enum": ["S01", "S02"]},
    "node_id": {"oneOf": [{"$ref": "#/$defs/nodeId"}, {"type": "null"}]},
    "actor_role": {"oneOf": [{"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 80}, {"type": "null"}]},
    "tool_name": {"oneOf": [{"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$", "maxLength": 120}, {"type": "null"}]},
    "tool_profile": {"oneOf": [{"$ref": "#/$defs/fileBinding"}, {"type": "null"}]},
    "exit_code": {"oneOf": [{"type": "integer"}, {"type": "null"}]},
    "accelerator_peak_memory_bytes": {"oneOf": [{"$ref": "#/$defs/metric"}, {"type": "null"}]},
    "retry_parent_session_id": {"oneOf": [{"$ref": "#/$defs/sessionId"}, {"type": "null"}]},
    "rework_observation_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/eventId"}},
    "supersedes_observation_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/eventId"}},
    "started_at": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
    "finished_at": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
    "active_elapsed_ms": {"oneOf": [{"$ref": "#/$defs/metric"}, {"type": "null"}]},
    "input_files": {"type": "array", "items": {"$ref": "#/$defs/fileBinding"}},
    "output_files": {"type": "array", "items": {"$ref": "#/$defs/fileBinding"}},
    "model_event_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/eventId"}},
    "model_summary": {"oneOf": [{"$ref": "#/$defs/fileBinding"}, {"type": "null"}]},
    "external_cost": {"oneOf": [{"$ref": "#/$defs/metric"}, {"type": "null"}]},
    "failure_class": {"oneOf": [{"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 120}, {"type": "null"}]},
    "invalid_read_count": {"type": "integer", "minimum": 0},
    "scope": {"const": "contract_observed"},
    "previous_record_hash": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "record_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "taskId": {"type": "string", "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$"},
    "sessionId": {"type": "string", "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$"},
    "runId": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "eventId": {"type": "string", "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$"},
    "nodeId": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "relativePath": {
      "type": "string", "minLength": 1, "maxLength": 512,
      "pattern": "^(?![~/])(?![A-Za-z]:)(?!.*(?:^|/)(?:\\.{1,2}|latest)(?:/|$))(?!.*[\\\\*?$%])[^\\\\]+$"
    },
    "fileBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["relative_path", "content_hash_algorithm", "content_hash", "size_bytes"],
      "properties": {
        "relative_path": {"$ref": "#/$defs/relativePath"}, "content_hash_algorithm": {"const": "sha256"},
        "content_hash": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "metric": {
      "type": "object", "additionalProperties": false,
      "required": ["value", "status", "source"],
      "properties": {
        "value": {"oneOf": [{"type": "number"}, {"type": "null"}]},
        "status": {"enum": ["measured", "estimated", "unavailable", "not_applicable"]},
        "source": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 80}
      }
    }
  }
}
