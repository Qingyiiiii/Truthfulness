{
  "$defs": {
    "ComponentBinding": {
      "additionalProperties": false,
      "properties": {
        "component_name": {
          "enum": [
            "ffmpeg",
            "asr",
            "ocr"
          ],
          "title": "Component Name",
          "type": "string"
        },
        "engine_version": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Engine Version",
          "type": "string"
        },
        "executable_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executable Sha256"
        },
        "file_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "File Sha256",
          "type": "string"
        },
        "local_files_only": {
          "const": true,
          "title": "Local Files Only",
          "type": "boolean"
        },
        "parameters_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Parameters Hash",
          "type": "string"
        },
        "plan_or_manifest_path": {
          "title": "Plan Or Manifest Path",
          "type": "string"
        },
        "resolved_revision": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Resolved Revision",
          "type": "string"
        },
        "runtime_download_allowed": {
          "const": false,
          "title": "Runtime Download Allowed",
          "type": "boolean"
        },
        "semantic_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Semantic Hash",
          "type": "string"
        }
      },
      "required": [
        "component_name",
        "engine_version",
        "resolved_revision",
        "parameters_hash",
        "plan_or_manifest_path",
        "file_sha256",
        "semantic_hash",
        "runtime_download_allowed",
        "local_files_only"
      ],
      "title": "ComponentBinding",
      "type": "object"
    },
    "FrozenArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_type": {
          "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$",
          "title": "Artifact Type",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "lifecycle_state": {
          "enum": [
            "validated",
            "frozen"
          ],
          "title": "Lifecycle State",
          "type": "string"
        },
        "record_id": {
          "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Record Id",
          "type": "string"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        },
        "validation_status": {
          "const": "passed",
          "title": "Validation Status",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "artifact_type",
        "record_id",
        "relative_path",
        "content_hash",
        "validation_status",
        "lifecycle_state"
      ],
      "title": "FrozenArtifactRef",
      "type": "object"
    },
    "FrozenFileRef": {
      "additionalProperties": false,
      "properties": {
        "file_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "File Sha256",
          "type": "string"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        },
        "semantic_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Semantic Hash"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "relative_path",
        "file_sha256",
        "size_bytes"
      ],
      "title": "FrozenFileRef",
      "type": "object"
    },
    "MediaAdapterBinding": {
      "additionalProperties": false,
      "properties": {
        "adapter_profile_version": {
          "const": "receipt_bound_ffmpeg_adapter_v1.0.0",
          "title": "Adapter Profile Version",
          "type": "string"
        },
        "argv_template": {
          "items": {
            "type": "string"
          },
          "minItems": 4,
          "title": "Argv Template",
          "type": "array"
        },
        "executable_path": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Executable Path",
          "type": "string"
        },
        "executable_sha256": {
          "const": "e7e7fb30477f717e6f55f9180a70386c62677ef8a4d4d1a5d948f4098aa3eb99",
          "title": "Executable Sha256",
          "type": "string"
        },
        "ffmpeg_version": {
          "const": "7.0.2-static",
          "title": "Ffmpeg Version",
          "type": "string"
        },
        "generic_subprocess_forbidden": {
          "const": true,
          "title": "Generic Subprocess Forbidden",
          "type": "boolean"
        },
        "output_policy": {
          "const": "declared_create_new_only",
          "title": "Output Policy",
          "type": "string"
        }
      },
      "required": [
        "adapter_profile_version",
        "ffmpeg_version",
        "executable_path",
        "executable_sha256",
        "argv_template",
        "output_policy",
        "generic_subprocess_forbidden"
      ],
      "title": "MediaAdapterBinding",
      "type": "object"
    },
    "NodeNetworkPolicy": {
      "additionalProperties": false,
      "properties": {
        "forbidden_services": {
          "items": {
            "enum": [
              "youtube",
              "gemini",
              "login_or_cookie",
              "private_source"
            ],
            "type": "string"
          },
          "title": "Forbidden Services",
          "type": "array"
        },
        "mode": {
          "enum": [
            "none",
            "public_web_evidence_only"
          ],
          "title": "Mode",
          "type": "string"
        },
        "open_limit": {
          "maximum": 120,
          "minimum": 0,
          "title": "Open Limit",
          "type": "integer"
        },
        "per_claim_query_limit": {
          "maximum": 3,
          "minimum": 0,
          "title": "Per Claim Query Limit",
          "type": "integer"
        },
        "per_claim_source_limit": {
          "maximum": 2,
          "minimum": 0,
          "title": "Per Claim Source Limit",
          "type": "integer"
        },
        "query_limit": {
          "maximum": 60,
          "minimum": 0,
          "title": "Query Limit",
          "type": "integer"
        }
      },
      "required": [
        "mode",
        "query_limit",
        "open_limit",
        "per_claim_query_limit",
        "per_claim_source_limit",
        "forbidden_services"
      ],
      "title": "NodeNetworkPolicy",
      "type": "object"
    },
    "OcrFrameDecodeRequestV1": {
      "additionalProperties": false,
      "properties": {
        "output_relative_path": {
          "title": "Output Relative Path",
          "type": "string"
        },
        "request_id": {
          "pattern": "^ocrframe_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Request Id",
          "type": "string"
        },
        "timestamp_ms": {
          "minimum": 0,
          "title": "Timestamp Ms",
          "type": "integer"
        },
        "trigger_id": {
          "pattern": "^ocrtrigger_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Trigger Id",
          "type": "string"
        }
      },
      "required": [
        "request_id",
        "trigger_id",
        "timestamp_ms",
        "output_relative_path"
      ],
      "title": "OcrFrameDecodeRequestV1",
      "type": "object"
    },
    "PlannedArtifactRef": {
      "additionalProperties": false,
      "description": "Identity frozen before a Session-local producer materializes content bytes.",
      "properties": {
        "artifact_id": {
          "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_type": {
          "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$",
          "title": "Artifact Type",
          "type": "string"
        },
        "content_hash": {
          "default": null,
          "title": "Content Hash",
          "type": "null"
        },
        "lifecycle_state": {
          "const": "planned",
          "title": "Lifecycle State",
          "type": "string"
        },
        "record_id": {
          "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Record Id",
          "type": "string"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        },
        "validation_status": {
          "const": "planned",
          "title": "Validation Status",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "artifact_type",
        "record_id",
        "relative_path",
        "validation_status",
        "lifecycle_state"
      ],
      "title": "PlannedArtifactRef",
      "type": "object"
    },
    "ReceiptBoundToolPolicy": {
      "additionalProperties": false,
      "properties": {
        "access_mode": {
          "const": "tool_managed",
          "title": "Access Mode",
          "type": "string"
        },
        "adapter_profile_version": {
          "const": "receipt_bound_ffmpeg_adapter_v1.0.0",
          "title": "Adapter Profile Version",
          "type": "string"
        },
        "content_read": {
          "const": "ffmpeg_declared_decode",
          "title": "Content Read",
          "type": "string"
        },
        "decode_allowed": {
          "const": true,
          "title": "Decode Allowed",
          "type": "boolean"
        },
        "executable_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Executable Sha256",
          "type": "string"
        }
      },
      "required": [
        "access_mode",
        "decode_allowed",
        "content_read",
        "executable_sha256",
        "adapter_profile_version"
      ],
      "title": "ReceiptBoundToolPolicy",
      "type": "object"
    },
    "ReceiptPathRefV1_1": {
      "additionalProperties": false,
      "properties": {
        "file_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "File Sha256",
          "type": "string"
        },
        "receipt_version": {
          "const": "input_materialization_v1.1.0",
          "title": "Receipt Version",
          "type": "string"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        },
        "semantic_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Semantic Hash",
          "type": "string"
        }
      },
      "required": [
        "relative_path",
        "receipt_version",
        "file_sha256",
        "semantic_hash"
      ],
      "title": "ReceiptPathRefV1_1",
      "type": "object"
    },
    "RegistryExpectedHead": {
      "additionalProperties": false,
      "properties": {
        "file_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "File Sha256",
          "type": "string"
        },
        "head_record_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Head Record Hash",
          "type": "string"
        },
        "head_record_id": {
          "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Head Record Id",
          "type": "string"
        },
        "record_count": {
          "minimum": 1,
          "title": "Record Count",
          "type": "integer"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        }
      },
      "required": [
        "relative_path",
        "record_count",
        "head_record_id",
        "head_record_hash",
        "file_sha256"
      ],
      "title": "RegistryExpectedHead",
      "type": "object"
    },
    "S01NodePlanV1_3": {
      "additionalProperties": false,
      "description": "Additive local-only warehouse node while preserving every v1.2 node.",
      "properties": {
        "conditional_outputs": {
          "items": {
            "type": "string"
          },
          "title": "Conditional Outputs",
          "type": "array"
        },
        "depends_on": {
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "execution_kind": {
          "enum": [
            "decision",
            "transform",
            "asr",
            "ocr_gate",
            "public_evidence",
            "aggregate",
            "warehouse_export"
          ],
          "title": "Execution Kind",
          "type": "string"
        },
        "media_adapter": {
          "anyOf": [
            {
              "$ref": "#/$defs/MediaAdapterBinding"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "network": {
          "$ref": "#/$defs/NodeNetworkPolicy"
        },
        "node_id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Node Id",
          "type": "string"
        },
        "ocr_frame_requests": {
          "items": {
            "$ref": "#/$defs/OcrFrameDecodeRequestV1"
          },
          "title": "Ocr Frame Requests",
          "type": "array"
        },
        "order": {
          "maximum": 13,
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "read_set": {
          "items": {
            "$ref": "#/$defs/S01ReadBindingV1_2"
          },
          "title": "Read Set",
          "type": "array"
        },
        "required_outputs": {
          "items": {
            "type": "string"
          },
          "title": "Required Outputs",
          "type": "array"
        },
        "success_condition": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Success Condition",
          "type": "string"
        },
        "telemetry_call_kind": {
          "anyOf": [
            {
              "enum": [
                "asr",
                "ocr",
                "external_research"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Telemetry Call Kind"
        },
        "write_set": {
          "items": {
            "$ref": "#/$defs/S01WriteBindingV1_2"
          },
          "title": "Write Set",
          "type": "array"
        }
      },
      "required": [
        "order",
        "node_id",
        "depends_on",
        "read_set",
        "write_set",
        "required_outputs",
        "conditional_outputs",
        "success_condition",
        "execution_kind",
        "network"
      ],
      "title": "S01NodePlanV1_3",
      "type": "object"
    },
    "S01ReadBindingV1_2": {
      "additionalProperties": false,
      "properties": {
        "access_policy": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReceiptBoundToolPolicy"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/FrozenArtifactRef"
            },
            {
              "$ref": "#/$defs/PlannedArtifactRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Ref"
