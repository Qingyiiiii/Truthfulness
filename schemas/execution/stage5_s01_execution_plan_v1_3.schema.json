        "execution_closure_receipt",
        "telemetry_ledger",
        "telemetry_summary",
        "observation_ledger",
        "final_dag_snapshot",
        "current_state",
        "checkpoint",
        "handoff",
        "handoff_markdown",
        "finalization_journal",
        "fresh_recovery_request",
