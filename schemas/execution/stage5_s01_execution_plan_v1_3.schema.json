  "$id": "urn:video-truthfulness:schema:stage5-s01-execution-plan:v1.3",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Thirteen-node S01 plan ending in an immutable warehouse export package.",
  "properties": {
    "attempt_no": {
      "const": 1,
      "title": "Attempt No",
      "type": "integer"
