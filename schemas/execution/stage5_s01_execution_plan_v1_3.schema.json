            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Producer Node Id"
        },
        "purpose": {
          "maxLength": 300,
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "read_source": {
          "enum": [
            "external_frozen",
            "prior_node_output"
          ],
          "title": "Read Source",
          "type": "string"
        },
        "receipt_path_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReceiptPathRefV1_1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        }
      },
      "required": [
        "relative_path",
        "read_source",
        "purpose"
      ],
      "title": "S01ReadBindingV1_2",
      "type": "object"
    },
