{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:model-call-event:v1",
  "title": "Video Truthfulness Model Call Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_call_event_version", "event_type", "event_id", "sequence_no", "recorded_at", "task_id",
    "session_id", "attempt_no", "run_id", "stage_id", "node_id", "actor_role", "provider",
    "call_kind", "invocation_surface", "instrumentation_mode", "recording_mode", "writer_id",
    "started_event_id", "started_at", "finished_at", "outcome", "error_class", "requested_model",
    "observed_model", "timing", "token_usage", "contract_refs", "closure", "previous_record_hash",
    "record_hash"
  ],
  "properties": {
    "model_call_event_version": {"const": "model_call_event_v1.0.0"},
    "event_type": {"enum": ["model_call.started", "model_call.finished", "model_ledger.closed"]},
    "event_id": {"$ref": "#/$defs/eventId"},
    "sequence_no": {"type": "integer", "minimum": 1},
    "recorded_at": {"$ref": "#/$defs/utcTimestamp"},
    "task_id": {"$ref": "#/$defs/taskId"},
    "session_id": {"$ref": "#/$defs/sessionId"},
    "attempt_no": {"type": "integer", "minimum": 1},
    "run_id": {"$ref": "#/$defs/runId"},
    "stage_id": {"enum": ["S01", "S02"]},
    "node_id": {"oneOf": [{"$ref": "#/$defs/nodeId"}, {"type": "null"}]},
    "actor_role": {"oneOf": [{"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 80}, {"type": "null"}]},
    "provider": {"oneOf": [{"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$", "maxLength": 80}, {"type": "null"}]},
    "call_kind": {"oneOf": [{"enum": ["llm", "asr", "ocr", "external_research"]}, {"type": "null"}]},
    "invocation_surface": {"oneOf": [{"enum": ["project_api", "codex_runtime", "browser_ui", "local_runtime"]}, {"type": "null"}]},
    "instrumentation_mode": {"oneOf": [{"enum": ["project_hook", "host_receipt", "external_ui"]}, {"type": "null"}]},
    "recording_mode": {"oneOf": [{"enum": ["synchronous", "retrospective_host_receipt", "retrospective_manual_receipt"]}, {"type": "null"}]},
    "writer_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]*$", "maxLength": 120},
    "started_event_id": {"oneOf": [{"$ref": "#/$defs/eventId"}, {"type": "null"}]},
    "started_at": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
    "finished_at": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
    "outcome": {"oneOf": [{"enum": ["succeeded", "failed", "cancelled"]}, {"type": "null"}]},
    "error_class": {"oneOf": [{"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$", "maxLength": 160}, {"type": "null"}]},
    "requested_model": {"oneOf": [{"$ref": "#/$defs/requestedModel"}, {"type": "null"}]},
    "observed_model": {"oneOf": [{"$ref": "#/$defs/observedModel"}, {"type": "null"}]},
    "timing": {"oneOf": [{"$ref": "#/$defs/timing"}, {"type": "null"}]},
    "token_usage": {"oneOf": [{"$ref": "#/$defs/tokenUsage"}, {"type": "null"}]},
    "contract_refs": {"oneOf": [{"$ref": "#/$defs/contractRefs"}, {"type": "null"}]},
    "closure": {"oneOf": [{"$ref": "#/$defs/closure"}, {"type": "null"}]},
    "previous_record_hash": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "record_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "eventId": {"type": "string", "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$"},
    "taskId": {"type": "string", "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$"},
    "sessionId": {"type": "string", "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$"},
    "runId": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "nodeId": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "requestedModel": {
      "type": "object", "additionalProperties": false, "required": ["name", "revision", "reasoning"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 160},
        "revision": {"oneOf": [{"type": "string", "maxLength": 160}, {"type": "null"}]},
        "reasoning": {"oneOf": [{"type": "string", "maxLength": 80}, {"type": "null"}]}
      }
    },
    "observedModel": {
      "type": "object", "additionalProperties": false,
      "required": ["value", "status", "source", "match_status"],
      "properties": {
        "value": {"oneOf": [{"type": "string", "maxLength": 160}, {"type": "null"}]},
        "status": {"enum": ["reported", "unavailable"]},
        "source": {"enum": ["provider_response", "runtime_metadata", "ui_label", "local_manifest", "not_exposed"]},
        "match_status": {"enum": ["match", "mismatch", "unverifiable"]}
      }
    },
    "usageMetric": {
      "type": "object", "additionalProperties": false, "required": ["value", "status", "source"],
      "properties": {
        "value": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
        "status": {"enum": ["measured", "derived", "unavailable", "not_applicable"]},
        "source": {"enum": ["provider_usage", "runtime_usage", "ui_usage", "sum_of_measured_components", "not_exposed", "not_applicable"]}
      }
    },
    "tokenUsage": {
      "type": "object", "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "total_tokens", "cached_tokens", "reasoning_tokens"],
      "properties": {
        "input_tokens": {"$ref": "#/$defs/usageMetric"}, "output_tokens": {"$ref": "#/$defs/usageMetric"},
        "total_tokens": {"$ref": "#/$defs/usageMetric"}, "cached_tokens": {"$ref": "#/$defs/usageMetric"},
        "reasoning_tokens": {"$ref": "#/$defs/usageMetric"}
      }
    },
    "elapsedMetric": {
      "type": "object", "additionalProperties": false, "required": ["value_ms", "status", "source"],
      "properties": {
        "value_ms": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
        "status": {"enum": ["measured", "derived", "unavailable", "not_applicable"]},
        "source": {"enum": ["monotonic_clock", "provider_timing", "receipt_interval", "not_exposed", "not_applicable"]}
      }
    },
    "timing": {
      "type": "object", "additionalProperties": false,
      "required": ["wall_elapsed", "active_elapsed", "provider_elapsed"],
      "properties": {
        "wall_elapsed": {"$ref": "#/$defs/elapsedMetric"}, "active_elapsed": {"$ref": "#/$defs/elapsedMetric"},
        "provider_elapsed": {"$ref": "#/$defs/elapsedMetric"}
      }
    },
    "contractRefs": {
      "type": "object", "additionalProperties": false,
      "required": ["workflow_version", "workflow_hash", "dag_version", "dag_hash", "prompt_version", "prompt_hash", "agent_profile_version", "agent_profile_hash"],
      "properties": {
        "workflow_version": {"type": "string", "minLength": 1, "maxLength": 120}, "workflow_hash": {"$ref": "#/$defs/sha256"},
        "dag_version": {"type": "string", "minLength": 1, "maxLength": 120}, "dag_hash": {"$ref": "#/$defs/sha256"},
        "prompt_version": {"oneOf": [{"type": "string", "maxLength": 120}, {"type": "null"}]},
        "prompt_hash": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "agent_profile_version": {"oneOf": [{"type": "string", "maxLength": 120}, {"type": "null"}]},
        "agent_profile_hash": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}
      }
    },
    "closure": {
      "type": "object", "additionalProperties": false,
      "required": ["started_count", "finished_count", "unmatched_count"],
      "properties": {
        "started_count": {"type": "integer", "minimum": 0}, "finished_count": {"type": "integer", "minimum": 0},
        "unmatched_count": {"const": 0}
      }
    }
  }
}
