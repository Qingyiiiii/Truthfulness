{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:model-usage-summary:v1",
  "title": "Video Truthfulness Model Usage Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_usage_summary_version", "task_id", "session_id", "attempt_no", "run_id", "stage_id",
    "ledger_file_hash", "ledger_closed_event_id", "closed_at", "complete", "started_count",
    "finished_count", "unmatched_count", "groups", "summary_hash"
  ],
  "properties": {
    "model_usage_summary_version": {"const": "model_usage_summary_v1.0.0"},
    "task_id": {"$ref": "#/$defs/taskId"},
    "session_id": {"$ref": "#/$defs/sessionId"},
    "attempt_no": {"type": "integer", "minimum": 1},
    "run_id": {"$ref": "#/$defs/runId"},
    "stage_id": {"enum": ["S01", "S02"]},
    "ledger_file_hash": {"$ref": "#/$defs/sha256"},
    "ledger_closed_event_id": {"$ref": "#/$defs/eventId"},
    "closed_at": {"$ref": "#/$defs/utcTimestamp"},
    "complete": {"const": true},
    "started_count": {"type": "integer", "minimum": 0},
    "finished_count": {"type": "integer", "minimum": 0},
    "unmatched_count": {"const": 0},
    "groups": {"type": "array", "items": {"$ref": "#/$defs/group"}},
    "summary_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "eventId": {"type": "string", "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$"},
    "taskId": {"type": "string", "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$"},
    "sessionId": {"type": "string", "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$"},
    "runId": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "coverage": {
      "type": "object", "additionalProperties": false,
      "required": ["measured_or_derived_sum", "measured_or_derived_count", "unavailable_count", "not_applicable_count"],
      "properties": {
        "measured_or_derived_sum": {"type": "integer", "minimum": 0},
        "measured_or_derived_count": {"type": "integer", "minimum": 0},
        "unavailable_count": {"type": "integer", "minimum": 0},
        "not_applicable_count": {"type": "integer", "minimum": 0}
      }
    },
    "tokenCoverage": {
      "type": "object", "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "total_tokens", "cached_tokens", "reasoning_tokens"],
      "properties": {
        "input_tokens": {"$ref": "#/$defs/coverage"}, "output_tokens": {"$ref": "#/$defs/coverage"},
        "total_tokens": {"$ref": "#/$defs/coverage"}, "cached_tokens": {"$ref": "#/$defs/coverage"},
        "reasoning_tokens": {"$ref": "#/$defs/coverage"}
      }
    },
    "group": {
      "type": "object", "additionalProperties": false,
      "required": [
        "provider", "invocation_surface", "actor_role", "call_kind", "requested_model", "observed_model",
        "observed_status", "call_count", "failed_count", "mismatch_count", "wall_elapsed_ms",
        "wall_elapsed_covered_count", "token_coverage"
      ],
      "properties": {
        "provider": {"type": "string"}, "invocation_surface": {"type": "string"}, "actor_role": {"type": "string"},
        "call_kind": {"type": "string"}, "requested_model": {"type": "string"},
        "observed_model": {"oneOf": [{"type": "string"}, {"type": "null"}]},
        "observed_status": {"enum": ["reported", "unavailable"]},
        "call_count": {"type": "integer", "minimum": 1}, "failed_count": {"type": "integer", "minimum": 0},
        "mismatch_count": {"type": "integer", "minimum": 0}, "wall_elapsed_ms": {"type": "integer", "minimum": 0},
        "wall_elapsed_covered_count": {"type": "integer", "minimum": 0},
        "token_coverage": {"$ref": "#/$defs/tokenCoverage"}
      }
    }
  }
}
