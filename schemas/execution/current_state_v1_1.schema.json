{
  "$defs": {
    "_CandidateNode": {
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Node Id",
          "type": "string"
        },
        "stage_id": {
          "pattern": "^S0[1-9]$",
          "title": "Stage Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "ready",
            "manual_gate",
            "blocked",
            "failed",
            "stale",
            "invalid"
          ],
          "title": "Status",
          "type": "string"
        },
        "reason": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "node_id",
        "stage_id",
        "status",
        "reason"
      ],
      "title": "_CandidateNode",
      "type": "object"
    },
    "_CompletedAction": {
      "additionalProperties": false,
      "properties": {
        "action_key": {
          "maxLength": 120,
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Action Key",
          "type": "string"
        },
        "summary": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "source_event_id": {
          "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Source Event Id",
          "type": "string"
        }
      },
      "required": [
        "action_key",
        "summary",
        "source_event_id"
      ],
      "title": "_CompletedAction",
      "type": "object"
    },
    "_ObservedAccess": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Artifact Id"
        },
        "record_id": {
          "anyOf": [
            {
              "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Record Id"
        },
        "relative_path": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "content_hash_algorithm": {
          "const": "sha256",
          "title": "Content Hash Algorithm",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "event_id": {
          "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Event Id",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "record_id",
        "relative_path",
        "content_hash_algorithm",
        "content_hash",
        "event_id"
      ],
      "title": "_ObservedAccess",
      "type": "object"
    },
    "_PendingHumanDecision": {
      "additionalProperties": false,
      "properties": {
        "decision_artifact_id": {
          "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Decision Artifact Id",
          "type": "string"
        },
        "gate_node_id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Gate Node Id",
          "type": "string"
        },
        "requested_event_id": {
          "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Requested Event Id",
          "type": "string"
        },
        "status": {
          "const": "pending",
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "decision_artifact_id",
        "gate_node_id",
        "requested_event_id",
        "status",
        "summary"
      ],
      "title": "_PendingHumanDecision",
      "type": "object"
    },
    "_RegistryHead": {
      "additionalProperties": false,
      "properties": {
        "registry_scope": {
          "enum": [
            "run",
            "cross_run"
          ],
          "title": "Registry Scope",
          "type": "string"
        },
        "relative_path": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "content_hash_algorithm": {
          "const": "sha256",
          "title": "Content Hash Algorithm",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "record_count": {
          "minimum": 0,
          "title": "Record Count",
          "type": "integer"
        },
        "artifact_count": {
          "minimum": 0,
          "title": "Artifact Count",
          "type": "integer"
        },
        "head_record_id": {
          "anyOf": [
            {
              "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Head Record Id"
        },
        "head_record_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Head Record Hash"
        }
      },
      "required": [
        "registry_scope",
        "relative_path",
        "content_hash_algorithm",
        "content_hash",
        "record_count",
        "artifact_count",
        "head_record_id",
        "head_record_hash"
      ],
      "title": "_RegistryHead",
      "type": "object"
    },
    "_RemainingAction": {
      "additionalProperties": false,
      "properties": {
        "action_key": {
          "maxLength": 120,
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Action Key",
          "type": "string"
        },
        "summary": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "action_key",
        "summary"
      ],
      "title": "_RemainingAction",
      "type": "object"
    },
    "_StateArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_type": {
          "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$",
          "title": "Artifact Type",
          "type": "string"
        },
        "record_id": {
          "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
          "title": "Record Id",
          "type": "string"
        },
        "relative_path": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "content_hash_algorithm": {
          "const": "sha256",
          "title": "Content Hash Algorithm",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "input_fingerprint": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Input Fingerprint"
        },
        "validation_status": {
          "enum": [
            "not_validated",
            "passed",
            "failed",
            "partial"
          ],
          "title": "Validation Status",
          "type": "string"
        },
        "lifecycle_state": {
          "enum": [
            "created",
            "validated",
            "frozen",
            "stale",
            "superseded",
            "invalid",
            "archived",
            "purged"
          ],
          "title": "Lifecycle State",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "artifact_type",
        "record_id",
        "relative_path",
        "content_hash_algorithm",
        "content_hash",
        "input_fingerprint",
        "validation_status",
        "lifecycle_state"
      ],
      "title": "_StateArtifactRef",
      "type": "object"
    },
    "_ValidationSummary": {
      "additionalProperties": false,
      "properties": {
        "overall_status": {
          "enum": [
            "passed",
            "failed",
            "partial",
            "not_run"
          ],
          "title": "Overall Status",
          "type": "string"
        },
        "passed_count": {
          "minimum": 0,
          "title": "Passed Count",
          "type": "integer"
        },
        "failed_count": {
          "minimum": 0,
          "title": "Failed Count",
          "type": "integer"
        },
        "partial_count": {
          "minimum": 0,
          "title": "Partial Count",
          "type": "integer"
        },
        "validators": {
          "items": {
            "$ref": "#/$defs/_ValidatorResult"
          },
          "title": "Validators",
          "type": "array"
        }
      },
      "required": [
        "overall_status",
        "passed_count",
        "failed_count",
        "partial_count",
        "validators"
      ],
      "title": "_ValidationSummary",
      "type": "object"
    },
    "_ValidatorResult": {
      "additionalProperties": false,
      "properties": {
        "validator_id": {
          "maxLength": 160,
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "title": "Validator Id",
          "type": "string"
        },
        "validator_version": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Validator Version",
          "type": "string"
        },
        "result": {
          "enum": [
            "passed",
            "failed",
            "partial"
          ],
          "title": "Result",
          "type": "string"
        },
        "validation_artifact_id": {
          "anyOf": [
            {
              "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Validation Artifact Id"
        }
      },
      "required": [
        "validator_id",
        "validator_version",
        "result",
        "validation_artifact_id"
      ],
      "title": "_ValidatorResult",
      "type": "object"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false,
  "properties": {
    "current_state_version": {
      "const": "current_state_v1.1.0",
      "title": "Current State Version",
      "type": "string"
    },
    "task_id": {
      "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Task Id",
      "type": "string"
    },
    "session_id": {
      "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Session Id",
      "type": "string"
    },
    "attempt_no": {
      "minimum": 1,
      "title": "Attempt No",
      "type": "integer"
    },
    "run_id": {
      "anyOf": [
        {
          "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Run Id"
    },
    "stage_id": {
      "pattern": "^S0[1-9]$",
      "title": "Stage Id",
      "type": "string"
    },
    "status": {
      "enum": [
        "IN_PROGRESS",
        "COMPLETED",
        "FAILED",
        "WAITING_FOR_HUMAN",
        "BLOCKED_BY_INPUT",
        "SKIPPED_BY_GATE"
      ],
      "title": "Status",
      "type": "string"
    },
    "as_of_event_id": {
      "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "As Of Event Id",
      "type": "string"
    },
    "as_of_occurred_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$",
      "title": "As Of Occurred At",
      "type": "string"
    },
    "event_count": {
      "minimum": 1,
      "title": "Event Count",
      "type": "integer"
    },
    "event_head_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Event Head Hash",
      "type": "string"
    },
    "registry_heads": {
      "items": {
        "$ref": "#/$defs/_RegistryHead"
      },
      "minItems": 1,
      "title": "Registry Heads",
      "type": "array"
    },
    "dag_version": {
      "const": "youtube_truthfulness_dag_v1.2.0"
    },
    "workflow_version": {
      "enum": [
        "youtube_truthfulness_workflow_v1.1.0",
        "youtube_truthfulness_workflow_v1.3.0"
      ]
    },
    "actual_read_set": {
      "items": {
        "$ref": "#/$defs/_ObservedAccess"
      },
      "title": "Actual Read Set",
      "type": "array"
    },
    "actual_write_set": {
      "items": {
        "$ref": "#/$defs/_ObservedAccess"
      },
      "title": "Actual Write Set",
      "type": "array"
    },
    "input_artifacts": {
      "items": {
        "$ref": "#/$defs/_StateArtifactRef"
      },
      "title": "Input Artifacts",
      "type": "array"
    },
    "output_artifacts": {
      "items": {
        "$ref": "#/$defs/_StateArtifactRef"
      },
      "title": "Output Artifacts",
      "type": "array"
    },
    "invalidated_artifacts": {
      "items": {
        "$ref": "#/$defs/_StateArtifactRef"
      },
      "title": "Invalidated Artifacts",
      "type": "array"
    },
    "completed_actions": {
      "items": {
        "$ref": "#/$defs/_CompletedAction"
      },
      "title": "Completed Actions",
      "type": "array"
    },
    "remaining_actions": {
      "items": {
        "$ref": "#/$defs/_RemainingAction"
      },
      "title": "Remaining Actions",
      "type": "array"
    },
    "pending_human_decisions": {
      "items": {
        "$ref": "#/$defs/_PendingHumanDecision"
      },
      "title": "Pending Human Decisions",
      "type": "array"
    },
    "validation_summary": {
      "$ref": "#/$defs/_ValidationSummary"
    },
    "candidate_next_nodes": {
      "items": {
        "$ref": "#/$defs/_CandidateNode"
      },
      "title": "Candidate Next Nodes",
      "type": "array"
    },
    "state_hash": {
      "$ref": "#/$defs/sha256"
    }
  },
  "required": [
    "current_state_version",
    "task_id",
    "session_id",
    "attempt_no",
    "run_id",
    "stage_id",
    "status",
    "as_of_event_id",
    "as_of_occurred_at",
    "event_count",
    "event_head_hash",
    "registry_heads",
    "dag_version",
    "workflow_version",
    "actual_read_set",
    "actual_write_set",
    "input_artifacts",
    "output_artifacts",
    "invalidated_artifacts",
    "completed_actions",
    "remaining_actions",
    "pending_human_decisions",
    "validation_summary",
    "candidate_next_nodes",
    "state_hash"
  ],
  "title": "Video Truthfulness Current State v1.1",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:current-state:v1.1",
  "allOf": [
    {
      "if": {
        "properties": {
          "stage_id": {
            "const": "S02"
          }
        }
      },
      "then": {
        "properties": {
          "workflow_version": {
            "const": "youtube_truthfulness_workflow_v1.3.0"
          }
        }
      },
      "else": {
        "properties": {
          "workflow_version": {
            "const": "youtube_truthfulness_workflow_v1.1.0"
          }
        }
      }
    }
  ]
}
