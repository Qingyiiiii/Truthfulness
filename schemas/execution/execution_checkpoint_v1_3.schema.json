{
  "$defs": {
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:video-truthfulness:schema:execution-checkpoint:v1.3",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "S01 warehouse-export successor checkpoint; projection remains pending.",
  "properties": {
    "bundle_artifact_ids": {
      "items": {
        "type": "string"
      },
      "title": "Bundle Artifact Ids",
      "type": "array"
    },
    "checkpoint_hash": {
      "$ref": "#/$defs/sha256"
    },
    "checkpoint_id": {
      "pattern": "^checkpoint_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Checkpoint Id",
      "type": "string"
    },
    "checkpoint_kind": {
      "const": "stage_boundary",
      "title": "Checkpoint Kind",
      "type": "string"
    },
    "checkpoint_schema_version": {
      "const": "execution_checkpoint_v1.3.0",
      "title": "Checkpoint Schema Version",
      "type": "string"
    },
    "created_at": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$",
      "title": "Created At",
      "type": "string"
    },
    "current_state_path": {
      "title": "Current State Path",
      "type": "string"
    },
    "current_state_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Current State Sha256",
      "type": "string"
    },
    "dag_snapshot_path": {
      "title": "Dag Snapshot Path",
      "type": "string"
    },
    "dag_snapshot_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Dag Snapshot Sha256",
      "type": "string"
    },
    "dag_version": {
      "const": "youtube_truthfulness_dag_v1.4.0",
      "title": "Dag Version",
      "type": "string"
    },
    "execution_closure_file_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Execution Closure File Sha256",
      "type": "string"
    },
    "execution_closure_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Execution Closure Hash",
      "type": "string"
    },
    "execution_closure_path": {
      "title": "Execution Closure Path",
      "type": "string"
    },
    "execution_plan_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Execution Plan Hash",
      "type": "string"
    },
    "observation_ledger_path": {
      "title": "Observation Ledger Path",
      "type": "string"
    },
    "observation_ledger_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Observation Ledger Sha256",
      "type": "string"
    },
    "project_version": {
      "const": "v0.2",
      "title": "Project Version",
      "type": "string"
    },
    "registry_file_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Registry File Sha256",
      "type": "string"
    },
    "registry_head_record_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Registry Head Record Hash",
      "type": "string"
    },
    "registry_head_record_id": {
      "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Registry Head Record Id",
      "type": "string"
    },
    "registry_record_count": {
      "minimum": 1,
      "title": "Registry Record Count",
      "type": "integer"
    },
    "run_id": {
      "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Run Id",
      "type": "string"
    },
    "runtime_trace_path": {
      "title": "Runtime Trace Path",
      "type": "string"
    },
    "runtime_trace_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Runtime Trace Sha256",
      "type": "string"
    },
    "session_id": {
      "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Session Id",
      "type": "string"
    },
    "stage_id": {
      "const": "S01",
      "title": "Stage Id",
      "type": "string"
    },
    "task_id": {
      "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Task Id",
      "type": "string"
    },
    "telemetry_ledger_path": {
      "title": "Telemetry Ledger Path",
      "type": "string"
    },
    "telemetry_ledger_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Telemetry Ledger Sha256",
      "type": "string"
    },
    "telemetry_summary_path": {
      "title": "Telemetry Summary Path",
      "type": "string"
    },
    "telemetry_summary_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Telemetry Summary Sha256",
      "type": "string"
    },
    "terminal_event_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Terminal Event Hash",
      "type": "string"
    },
    "terminal_event_id": {
      "pattern": "^event_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Terminal Event Id",
      "type": "string"
    },
    "terminal_event_sequence_no": {
      "minimum": 1,
      "title": "Terminal Event Sequence No",
      "type": "integer"
    },
    "terminal_state": {
      "enum": [
        "COMPLETED",
        "WAITING_FOR_HUMAN"
      ],
      "title": "Terminal State",
      "type": "string"
    },
    "warehouse_export_artifact_id": {
      "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$",
      "title": "Warehouse Export Artifact Id",
      "type": "string"
    },
    "warehouse_export_logical_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Warehouse Export Logical Hash",
      "type": "string"
    },
    "warehouse_export_manifest_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Warehouse Export Manifest Hash",
      "type": "string"
    },
    "warehouse_export_row_count": {
      "minimum": 1,
      "title": "Warehouse Export Row Count",
      "type": "integer"
    },
    "warehouse_export_row_counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Warehouse Export Row Counts",
      "type": "object"
    },
    "warehouse_projection_status": {
      "const": "pending",
      "title": "Warehouse Projection Status",
      "type": "string"
    },
    "workflow_version": {
      "const": "youtube_truthfulness_workflow_v1.3.0",
      "title": "Workflow Version",
      "type": "string"
    }
  },
  "required": [
    "checkpoint_schema_version",
    "checkpoint_id",
    "checkpoint_kind",
    "project_version",
    "run_id",
    "task_id",
    "session_id",
    "execution_plan_hash",
    "stage_id",
    "terminal_state",
    "workflow_version",
    "dag_version",
    "terminal_event_id",
    "terminal_event_hash",
    "terminal_event_sequence_no",
    "registry_record_count",
    "registry_head_record_id",
    "registry_head_record_hash",
    "registry_file_sha256",
    "dag_snapshot_path",
    "dag_snapshot_sha256",
    "current_state_path",
    "current_state_sha256",
    "bundle_artifact_ids",
    "telemetry_summary_path",
    "telemetry_summary_sha256",
    "telemetry_ledger_path",
    "telemetry_ledger_sha256",
    "observation_ledger_path",
    "observation_ledger_sha256",
    "runtime_trace_path",
    "runtime_trace_sha256",
    "execution_closure_path",
    "execution_closure_file_sha256",
    "execution_closure_hash",
    "created_at",
    "checkpoint_hash",
    "warehouse_export_artifact_id",
    "warehouse_export_manifest_hash",
    "warehouse_export_logical_hash",
    "warehouse_export_row_count",
    "warehouse_export_row_counts",
    "warehouse_projection_status"
  ],
  "title": "Stage 5 S01 execution checkpoint v1.3",
  "type": "object"
}
