{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:manual-external-input-receipt:v1",
  "title": "Video Truthfulness Manual External Input Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_version", "receipt_kind", "receipt_id", "task_id", "session_id", "attempt_no", "run_id",
    "source_depth_request_id", "prompt_artifact_id", "source_relative_path", "user_signal_at",
    "signal_semantic_hash", "result_ready", "permission", "stat_before", "stat_after", "content_hash",
    "size_bytes", "media_type", "receipt_hash"
  ],
  "properties": {
    "receipt_version": {"const": "manual_external_input_receipt_v1.0.0"},
    "receipt_kind": {"enum": ["result_ready", "materialization"]},
    "receipt_id": {"type": "string", "pattern": "^receipt_[0-9a-hjkmnp-tv-z]{26}$"},
    "task_id": {"$ref": "#/$defs/taskId"},
    "session_id": {"$ref": "#/$defs/sessionId"},
    "attempt_no": {"type": "integer", "minimum": 1},
    "run_id": {"$ref": "#/$defs/runId"},
    "source_depth_request_id": {"type": "string", "pattern": "^source_depth_request_[0-9a-hjkmnp-tv-z]{26}$"},
    "prompt_artifact_id": {"$ref": "#/$defs/artifactId"},
    "source_relative_path": {"$ref": "#/$defs/relativePath"},
    "user_signal_at": {"$ref": "#/$defs/utcTimestamp"},
    "signal_semantic_hash": {"$ref": "#/$defs/sha256"},
    "result_ready": {"const": true},
    "permission": {"const": "capture_only"},
    "stat_before": {"oneOf": [{"$ref": "#/$defs/fileStat"}, {"type": "null"}]},
    "stat_after": {"oneOf": [{"$ref": "#/$defs/fileStat"}, {"type": "null"}]},
    "content_hash": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "size_bytes": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
    "media_type": {"oneOf": [{"enum": ["application/json", "text/markdown", "text/plain"]}, {"type": "null"}]},
    "receipt_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "taskId": {"type": "string", "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$"},
    "sessionId": {"type": "string", "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$"},
    "runId": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "artifactId": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "relativePath": {
      "type": "string", "minLength": 1, "maxLength": 512,
      "pattern": "^(?![~/])(?![A-Za-z]:)(?!.*(?:^|/)(?:\\.{1,2}|latest)(?:/|$))(?!.*[\\\\*?$%])[^\\\\]+$"
    },
    "fileStat": {
      "type": "object", "additionalProperties": false,
      "required": ["device", "inode", "size_bytes", "mtime_ns", "mode"],
      "properties": {
        "device": {"type": "integer", "minimum": 0}, "inode": {"type": "integer", "minimum": 0},
        "size_bytes": {"type": "integer", "minimum": 0}, "mtime_ns": {"type": "integer", "minimum": 0},
        "mode": {"type": "integer", "minimum": 0}
      }
    }
  }
}
