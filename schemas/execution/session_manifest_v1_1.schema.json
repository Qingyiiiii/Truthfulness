{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:session-manifest:v1.1",
  "title": "Video Truthfulness Session Manifest v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_manifest_version", "project_version", "storage_version", "release_id", "task_id", "session_id", "attempt_no", "task_scope", "run_id", "stage_id", "dag_node_id", "parent_checkpoint_id", "bootstrap_refs", "agent_profile_version", "agent_runtime_version", "workflow_version", "dag_version", "schema_versions", "prompt_version", "code_ref", "environment_ref", "declared_read_set", "declared_write_set", "human_gate_policy", "created_at", "manifest_hash"],
  "properties": {
    "session_manifest_version": {"const": "session_manifest_v1.1.0"},
    "project_version": {"const": "v0.2"},
    "storage_version": {"const": "V02"},
    "release_id": {"const": "truthfulness_v0.2_youtube_video"},
    "task_id": {"$ref": "#/$defs/taskId"},
    "session_id": {"$ref": "#/$defs/sessionId"},
    "attempt_no": {"type": "integer", "minimum": 1},
    "task_scope": {"enum": ["run", "cross_run"]},
    "run_id": {"oneOf": [{"$ref": "#/$defs/runId"}, {"type": "null"}]},
    "stage_id": {"$ref": "#/$defs/stageId"},
    "dag_node_id": {"type": "null"},
    "parent_checkpoint_id": {"oneOf": [{"$ref": "#/$defs/checkpointId"}, {"type": "null"}]},
    "bootstrap_refs": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/bootstrapRef"}, "uniqueItems": true},
    "agent_profile_version": {"$ref": "#/$defs/agentProfileVersion"},
    "agent_runtime_version": {"type": "string", "minLength": 1, "maxLength": 120},
    "workflow_version": {"enum": ["youtube_truthfulness_workflow_v1.1.0", "youtube_truthfulness_workflow_v1.3.0"]},
    "dag_version": {"const": "youtube_truthfulness_dag_v1.2.0"},
    "schema_versions": {"type": "array", "minItems": 1, "maxItems": 1024, "contains": {"const": "session_manifest_v1.1.0"}, "items": {"$ref": "#/$defs/schemaVersion"}, "uniqueItems": true},
    "prompt_version": {"$ref": "#/$defs/promptVersion"},
    "code_ref": {"$ref": "#/$defs/codeRef"},
    "environment_ref": {"$ref": "#/$defs/environmentRef"},
    "declared_read_set": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/scopeEntry"}, "uniqueItems": true},
    "declared_write_set": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/scopeEntry"}, "uniqueItems": true},
    "human_gate_policy": {"$ref": "#/$defs/humanGatePolicy"},
    "created_at": {"$ref": "#/$defs/utcTimestamp"},
    "manifest_hash": {"$ref": "#/$defs/sha256"}
  },
  "allOf": [
    {"if": {"properties": {"task_scope": {"const": "run"}}}, "then": {"properties": {"run_id": {"$ref": "#/$defs/runId"}}}, "else": {"properties": {"run_id": {"type": "null"}}}},
    {"if": {"properties": {"parent_checkpoint_id": {"type": "null"}}}, "then": {"properties": {"bootstrap_refs": {"minItems": 1}}}},
    {"if": {"properties": {"stage_id": {"const": "S02"}}}, "then": {"properties": {"workflow_version": {"const": "youtube_truthfulness_workflow_v1.3.0"}}}, "else": {"properties": {"workflow_version": {"const": "youtube_truthfulness_workflow_v1.1.0"}}}}
  ],
  "$defs": {
    "taskId": {"type": "string", "pattern": "^task_[0-9a-hjkmnp-tv-z]{26}$"},
    "sessionId": {"type": "string", "pattern": "^session_[0-9a-hjkmnp-tv-z]{26}$"},
    "runId": {"type": "string", "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "artifactId": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
    "checkpointId": {"type": "string", "pattern": "^checkpoint_[0-9a-hjkmnp-tv-z]{26}$"},
    "stageId": {"type": "string", "pattern": "^S0[1-9]$"},
    "dagNodeId": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitObjectId": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"},
    "relativePath": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?![~/])(?![A-Za-z]:)(?!.*(?:^|/)(?:\\.{1,2}|latest)(?:/|$))(?!.*[\\\\*?$%])[^\\\\]+$"},
    "schemaVersion": {"type": "string", "pattern": "^[a-z][a-z0-9_]*_v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "promptVersion": {"type": "string", "pattern": "^[a-z][a-z0-9_]*_prompt_v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "agentProfileVersion": {"type": "string", "pattern": "^[a-z][a-z0-9_]*_agent_v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "gitBootstrapRef": {"type": "object", "additionalProperties": false, "required": ["ref_type", "object_id", "description"], "properties": {"ref_type": {"enum": ["git_commit", "git_tree"]}, "object_id": {"$ref": "#/$defs/gitObjectId"}, "description": {"type": "string", "minLength": 1, "maxLength": 240}}},
    "fileBootstrapRef": {"type": "object", "additionalProperties": false, "required": ["ref_type", "relative_path", "content_hash_algorithm", "content_hash", "purpose"], "properties": {"ref_type": {"enum": ["document", "working_tree_manifest", "registry", "dag_config"]}, "relative_path": {"$ref": "#/$defs/relativePath"}, "content_hash_algorithm": {"const": "sha256"}, "content_hash": {"$ref": "#/$defs/sha256"}, "purpose": {"type": "string", "minLength": 1, "maxLength": 240}}},
    "bootstrapRef": {"oneOf": [{"$ref": "#/$defs/gitBootstrapRef"}, {"$ref": "#/$defs/fileBootstrapRef"}]},
    "artifactScope": {"type": "object", "additionalProperties": false, "required": ["scope_type", "artifact_id", "purpose"], "properties": {"scope_type": {"const": "artifact"}, "artifact_id": {"$ref": "#/$defs/artifactId"}, "purpose": {"type": "string", "minLength": 1, "maxLength": 200}}},
    "pathScope": {"type": "object", "additionalProperties": false, "required": ["scope_type", "relative_path", "purpose"], "properties": {"scope_type": {"const": "path"}, "relative_path": {"$ref": "#/$defs/relativePath"}, "purpose": {"type": "string", "minLength": 1, "maxLength": 200}}},
    "pathPrefixScope": {"type": "object", "additionalProperties": false, "required": ["scope_type", "relative_path", "recursive", "purpose"], "properties": {"scope_type": {"const": "path_prefix"}, "relative_path": {"$ref": "#/$defs/relativePath"}, "recursive": {"type": "boolean"}, "purpose": {"type": "string", "minLength": 1, "maxLength": 200}}},
    "scopeEntry": {"oneOf": [{"$ref": "#/$defs/artifactScope"}, {"$ref": "#/$defs/pathScope"}, {"$ref": "#/$defs/pathPrefixScope"}]},
    "codeRef": {"type": "object", "additionalProperties": false, "required": ["git_commit", "working_tree_dirty", "working_tree_manifest_path", "working_tree_manifest_hash"], "properties": {"git_commit": {"$ref": "#/$defs/gitObjectId"}, "working_tree_dirty": {"type": "boolean"}, "working_tree_manifest_path": {"oneOf": [{"$ref": "#/$defs/relativePath"}, {"type": "null"}]}, "working_tree_manifest_hash": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}}, "allOf": [{"if": {"properties": {"working_tree_dirty": {"const": true}}}, "then": {"properties": {"working_tree_manifest_path": {"$ref": "#/$defs/relativePath"}, "working_tree_manifest_hash": {"$ref": "#/$defs/sha256"}}}, "else": {"properties": {"working_tree_manifest_path": {"type": "null"}, "working_tree_manifest_hash": {"type": "null"}}}}]},
    "environmentRef": {"type": "object", "additionalProperties": false, "required": ["runtime_name", "runtime_version", "os_family", "architecture", "dependency_manifest_path", "dependency_manifest_hash"], "properties": {"runtime_name": {"type": "string", "minLength": 1, "maxLength": 80}, "runtime_version": {"type": "string", "minLength": 1, "maxLength": 80}, "os_family": {"enum": ["windows", "linux", "macos", "other"]}, "architecture": {"type": "string", "minLength": 1, "maxLength": 80}, "dependency_manifest_path": {"oneOf": [{"$ref": "#/$defs/relativePath"}, {"type": "null"}]}, "dependency_manifest_hash": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]}}, "oneOf": [{"properties": {"dependency_manifest_path": {"type": "null"}, "dependency_manifest_hash": {"type": "null"}}}, {"properties": {"dependency_manifest_path": {"$ref": "#/$defs/relativePath"}, "dependency_manifest_hash": {"$ref": "#/$defs/sha256"}}}]},
    "humanGatePolicy": {"type": "object", "additionalProperties": false, "required": ["approval_required", "gate_node_ids", "decision_artifact_required", "implicit_approval_allowed"], "properties": {"approval_required": {"type": "boolean"}, "gate_node_ids": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/dagNodeId"}, "uniqueItems": true}, "decision_artifact_required": {"type": "boolean"}, "implicit_approval_allowed": {"const": false}}}
  }
}
