{
  "$defs": {
    "GateStatus": {
      "description": "Task-specific quality-gate outcome.",
      "enum": [
        "pass",
        "quarantine",
        "reject"
      ],
      "title": "GateStatus",
      "type": "string"
    },
    "OriginType": {
      "description": "Where a record came from.",
      "enum": [
        "human_gold",
        "machine_candidate",
        "synthetic",
        "derived"
      ],
      "title": "OriginType",
      "type": "string"
    },
    "TaskGateResult": {
      "additionalProperties": false,
      "description": "Explain why a record may or may not enter one task.",
      "properties": {
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/GateStatus"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "status"
      ],
      "title": "TaskGateResult",
      "type": "object"
    },
    "UsageScope": {
      "description": "Allowed publication/use boundary for a source snapshot.",
      "enum": [
        "private_only",
        "public_synthetic",
        "approved_public",
        "unknown"
      ],
      "title": "UsageScope",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Canonical quality/lineage view of one upstream annotation record.",
  "properties": {
    "checkability": {
      "default": "",
      "title": "Checkability",
      "type": "string"
    },
    "claim_id": {
      "title": "Claim Id",
      "type": "string"
    },
    "claim_text": {
      "title": "Claim Text",
      "type": "string"
    },
    "claim_type": {
      "default": "",
      "title": "Claim Type",
      "type": "string"
    },
    "domain": {
      "default": "",
      "title": "Domain",
      "type": "string"
    },
    "duplicate_cluster_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Duplicate Cluster Id"
    },
    "evidence_completeness": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Evidence Completeness",
      "type": "number"
    },
    "evidence_quality": {
      "default": "",
      "title": "Evidence Quality",
      "type": "string"
    },
    "gate_status_by_task": {
      "additionalProperties": {
        "$ref": "#/$defs/TaskGateResult"
      },
      "title": "Gate Status By Task",
      "type": "object"
    },
    "generated_at": {
      "title": "Generated At",
      "type": "string"
    },
    "include_decision": {
      "default": "",
      "title": "Include Decision",
      "type": "string"
    },
    "input_content_hash": {
      "title": "Input Content Hash",
      "type": "string"
    },
    "language": {
      "title": "Language",
      "type": "string"
    },
    "noise_patterns": {
      "items": {
        "type": "string"
      },
      "title": "Noise Patterns",
      "type": "array"
    },
    "normalized_content_hash": {
      "title": "Normalized Content Hash",
      "type": "string"
    },
    "normalized_text": {
      "title": "Normalized Text",
      "type": "string"
    },
    "origin": {
      "$ref": "#/$defs/OriginType"
    },
    "output_dataset_version": {
      "title": "Output Dataset Version",
      "type": "string"
    },
    "parent_claim_id": {
      "title": "Parent Claim Id",
      "type": "string"
    },
    "pii_flags": {
      "items": {
        "type": "string"
      },
      "title": "Pii Flags",
      "type": "array"
    },
    "pipeline_version": {
      "title": "Pipeline Version",
      "type": "string"
    },
    "quality_flags": {
      "items": {
        "type": "string"
      },
      "title": "Quality Flags",
      "type": "array"
    },
    "raw_context": {
      "default": "",
      "title": "Raw Context",
      "type": "string"
    },
    "recommended_action": {
      "default": "",
      "title": "Recommended Action",
      "type": "string"
    },
    "record_id": {
      "title": "Record Id",
      "type": "string"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "quality_record_v1",
      "title": "Schema Version",
      "type": "string"
    },
    "source_dataset_version": {
      "title": "Source Dataset Version",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "source_record_id": {
      "title": "Source Record Id",
      "type": "string"
    },
    "source_schema_version": {
      "title": "Source Schema Version",
      "type": "string"
    },
    "split": {
      "title": "Split",
      "type": "string"
    },
    "split_group_id": {
      "title": "Split Group Id",
      "type": "string"
    },
    "status": {
      "title": "Status",
      "type": "string"
    },
    "training_use": {
      "default": "",
      "title": "Training Use",
      "type": "string"
    },
    "usage_scope": {
      "$ref": "#/$defs/UsageScope"
    }
  },
  "required": [
    "pipeline_version",
    "output_dataset_version",
    "source_dataset_version",
    "source_schema_version",
    "record_id",
    "source_record_id",
    "source_id",
    "run_id",
    "claim_id",
    "parent_claim_id",
    "origin",
    "usage_scope",
    "claim_text",
    "normalized_text",
    "status",
    "input_content_hash",
    "normalized_content_hash",
    "language",
    "split_group_id",
    "split",
    "evidence_completeness",
    "gate_status_by_task",
    "generated_at"
  ],
  "title": "QualityRecord",
  "type": "object"
}
