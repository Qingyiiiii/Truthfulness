{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:video-truthfulness:schema:artifact-record:v1.1",
  "title": "Video Truthfulness Artifact Registry Record v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "registry_schema_version",
    "record_revision",
    "recorded_at",
    "previous_record_id",
    "previous_record_hash",
    "record_hash",
    "artifact_id",
    "artifact_type",
    "logical_name",
    "container_kind",
    "project_version",
    "storage_version",
    "release_id",
    "relative_path",
    "storage_scope",
    "media_type",
    "size_bytes",
    "content_hash_algorithm",
    "content_hash",
    "producer_type",
    "schema_versions",
    "tool_versions",
    "upstream_artifact_ids",
    "upstream_entity_refs",
    "authority_level",
    "lifecycle_state",
    "validation_status",
    "validation_artifact_ids",
    "privacy_class",
    "access_scope",
    "retention_policy",
    "created_at",
    "supersedes"
  ],
  "properties": {
    "record_id": {"type": "string", "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$"},
    "registry_schema_version": {"const": "artifact_record_v1.1.0"},
    "record_revision": {"type": "integer", "minimum": 1},
    "recorded_at": {"type": "string", "format": "date-time"},
    "previous_record_id": {"type": ["string", "null"], "pattern": "^record_[0-9a-hjkmnp-tv-z]{26}$"},
    "previous_record_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "record_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact_id": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
    "artifact_type": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"},
    "logical_name": {"type": "string", "minLength": 1, "maxLength": 160},
    "container_kind": {"enum": ["file", "directory", "jsonl_container", "entity_index", "decision", "package"]},
    "project_version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+$"},
    "storage_version": {"enum": ["V01", "V02"]},
    "release_id": {"const": "truthfulness_v0.2_youtube_video"},
    "source_platform": {"type": ["string", "null"], "enum": ["youtube", "bilibili", null]},
    "source_id": {"type": ["string", "null"], "pattern": "^(?:youtube_[A-Za-z0-9_-]{11}|bilibili_BV[0-9A-Za-z]{10})$"},
    "run_id": {"type": ["string", "null"], "pattern": "^run_[0-9a-hjkmnp-tv-z]{26}$"},
    "batch_id": {"type": ["string", "null"], "pattern": "^batch_[0-9a-hjkmnp-tv-z]{26}$"},
    "dataset_build_id": {"type": ["string", "null"], "pattern": "^dataset_build_[0-9a-hjkmnp-tv-z]{26}$"},
    "dataset_version": {"type": ["string", "null"], "maxLength": 120},
    "exp_id": {"type": ["string", "null"], "pattern": "^exp_[0-9a-hjkmnp-tv-z]{26}$"},
    "stage_id": {"type": ["string", "null"], "pattern": "^S0[1-9]$"},
    "dag_node_id": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]*$"},
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+(?:/[^\\\\]+)*$"
    },
    "storage_scope": {"enum": ["run", "cross_run"]},
    "media_type": {"type": "string", "minLength": 1, "maxLength": 120},
    "size_bytes": {"type": "integer", "minimum": 0},
    "content_hash_algorithm": {"const": "sha256"},
    "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "semantic_hash_algorithm": {"type": ["string", "null"], "enum": ["sha256", null]},
    "semantic_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "entity_index_artifact_id": {"type": ["string", "null"], "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
    "producer_type": {"enum": ["external_source", "human", "agent", "workflow", "migration", "projection_builder"]},
    "writer_agent_id": {"type": ["string", "null"], "maxLength": 160},
    "agent_profile_version": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9_]*_agent_v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "agent_runtime_version": {"type": ["string", "null"], "minLength": 1, "maxLength": 120},
    "workflow_id": {"type": ["string", "null"], "maxLength": 160},
    "workflow_version": {"type": ["string", "null"], "maxLength": 160},
    "schema_versions": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "prompt_id": {"type": ["string", "null"], "maxLength": 160},
    "prompt_version": {"type": ["string", "null"], "maxLength": 120},
    "dag_version": {"type": ["string", "null"], "maxLength": 160},
    "code_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "tool_versions": {"type": "object", "additionalProperties": {"type": "string"}},
    "parameters_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "upstream_artifact_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
      "uniqueItems": true
    },
    "upstream_entity_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entity_id", "entity_type", "container_artifact_id"],
        "properties": {
          "entity_id": {"type": "string", "minLength": 1},
          "entity_type": {"type": "string", "minLength": 1},
          "container_artifact_id": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"}
        }
      }
    },
    "input_fingerprint": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "authority_level": {"enum": ["raw_source", "human_authoritative", "machine_derived", "projection", "cache"]},
    "lifecycle_state": {"enum": ["created", "validated", "frozen", "stale", "superseded", "invalid", "archived", "purged"]},
    "validation_status": {"enum": ["not_validated", "passed", "failed", "partial"]},
    "validation_artifact_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
      "uniqueItems": true
    },
    "privacy_class": {"enum": ["private_raw", "private_derived", "restricted_human", "public_synthetic", "public_aggregate"]},
    "access_scope": {"enum": ["local_private", "project_private", "public"]},
    "retention_policy": {"type": "string", "minLength": 1, "maxLength": 160},
    "created_at": {"type": "string", "format": "date-time"},
    "validated_at": {"type": ["string", "null"], "format": "date-time"},
    "frozen_at": {"type": ["string", "null"], "format": "date-time"},
    "archived_at": {"type": ["string", "null"], "format": "date-time"},
    "supersedes": {
      "type": "array",
      "items": {"type": "string", "pattern": "^artifact_[0-9a-hjkmnp-tv-z]{26}$"},
      "uniqueItems": true
    },
    "change_reason": {"type": ["string", "null"], "maxLength": 500},
    "metadata_revision_reason": {"type": ["string", "null"], "maxLength": 500}
  }
}
