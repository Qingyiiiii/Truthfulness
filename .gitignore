# =============================================================================
# Public snapshot allowlist
# =============================================================================
#
# Default policy: ignore every repository-root entry, then re-include only the
# files that have been reviewed as public showcase material. A new file remains
# private until it receives an explicit `!` rule below.
#
# Important: .gitignore does not remove files that are already tracked. Validate
# this policy with:
#
#   git ls-files -ci --exclude-standard
#   git status --short --ignored
#

/*


# =============================================================================
# A. Reviewed public root files
# =============================================================================

!/.dockerignore
!/.env.example
!/.gitignore
!/Dockerfile
!/LICENSE
!/README.md
!/compose.yaml
!/pyproject.toml


# =============================================================================
# B. Reviewed public application and configuration files
# =============================================================================

!/app/
/app/*
!/app/README.md
!/app/streamlit_app.py

!/configs/
/configs/*
!/configs/README.md
!/configs/agent-requirements.txt
!/configs/demo1.local.example.toml
!/configs/train_baseline.smoke.example.toml
!/configs/training_data_quality.example.toml
!/configs/ubuntu-wsl-requirements.freeze.txt
!/configs/version_id_policy.toml


# =============================================================================
# C. Reviewed public documentation
# =============================================================================

!/docs/
/docs/*
!/docs/README.md
!/docs/agent_rag.md
!/docs/file_layout.md
!/docs/interfaces.md
!/docs/training_data_quality.md
!/docs/version_and_id_system.md

!/models/
/models/*
!/models/README.md

!/runs/
/runs/*
!/runs/README.md

# Only aggregate/schema reports are public. Real reports and versioned run
# reports remain private until separately reviewed.
!/report/
/report/*
!/report/Annotation-example.md
!/report/v0.1成果汇报.md

# Architecture drafts, internal prompts, old-plan snapshots, workflows and
# acceptance reports remain private. Only the sanitized reference is public.
!/Optmize/
/Optmize/*
!/Optmize/优化方案参考.md


# =============================================================================
# D. Reviewed synthetic examples and public evaluation fixtures
# =============================================================================

!/evals/
/evals/*
!/evals/README.md
!/evals/agent_cases.jsonl

!/examples/
/examples/*
!/examples/README.md

!/examples/agent_demo/
/examples/agent_demo/*
!/examples/agent_demo/README.md
!/examples/agent_demo/sources.jsonl

!/examples/offline_demo/
/examples/offline_demo/*
!/examples/offline_demo/README.md
!/examples/offline_demo/evidence.json
!/examples/offline_demo/transcript.json

!/examples/training_data/
/examples/training_data/*
!/examples/training_data/README.md
!/examples/training_data/PUBLIC_DEMO_SUMMARY.md
!/examples/training_data/input.synthetic.jsonl
!/examples/training_data/splits.synthetic.jsonl


# =============================================================================
# E. Reviewed public schemas and schema exporters
# =============================================================================

!/schemas/
/schemas/*
!/schemas/README.md
!/schemas/legacy_run_id_map_v1.schema.json
!/schemas/run_identity_v1.schema.json

!/schemas/training_data/
/schemas/training_data/*
!/schemas/training_data/preference_pair_v1.schema.json
!/schemas/training_data/quality_record_v1.schema.json
!/schemas/training_data/sft_example_v1.schema.json
!/schemas/training_data/synthetic_example_v1.schema.json

!/scripts/
/scripts/*
!/scripts/export_training_data_schemas.py
!/scripts/start_agent_demo.sh
!/scripts/ubuntu_wsl_asr_gpu_check.sh
!/scripts/ubuntu_wsl_repro_check.sh
!/scripts/ubuntu_wsl_streamlit.sh
!/scripts/validate_version_ids.py


# =============================================================================
# F. Reviewed public source files
# =============================================================================

!/src/
/src/*
!/src/README.md

!/src/video_truthfulness/
/src/video_truthfulness/*
!/src/video_truthfulness/README.md
!/src/video_truthfulness/__init__.py
!/src/video_truthfulness/agent_config.py
