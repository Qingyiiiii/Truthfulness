# The self-contained extractive generator is the reproducible default.
TRUTHFULNESS_LLM_PROVIDER=extractive

# Optional local Ollama mode. Generated JSON still passes strict Pydantic validation.
# TRUTHFULNESS_LLM_PROVIDER=ollama
# TRUTHFULNESS_LLM_BASE_URL=http://host.docker.internal:11434
# TRUTHFULNESS_LLM_MODEL=deepseek-r1:7b

TRUTHFULNESS_EMBEDDING_BACKEND=fastembed
TRUTHFULNESS_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Private Ubuntu ext4 mapping for the V02 Claim warehouse. Keep the real
# absolute path in the local environment only; public records store the
# logical storage_root_ref `ubuntu_v02_claim_warehouse`.
# VIDEO_TRUTHFULNESS_WAREHOUSE_V02_ROOT=
